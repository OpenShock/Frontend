{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", ".svelte-kit/**"]
		},
		"check": {
			"dependsOn": ["^build"]
		},
		"lint": {},
		"test": {
			"dependsOn": ["^build"]
		},
		"test:unit": {
			"dependsOn": ["^build"]
		}
	}
}
