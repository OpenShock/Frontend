NODE_PATH=src

PUBLIC_SITE_NAME=OpenShock
PUBLIC_SITE_DESCRIPTION=a free and open-source ecosystem to control various shock collars over the internet.
PUBLIC_GITHUB_PROJECT_URL=https://github.com/OpenShock
PUBLIC_DISCORD_INVITE_URL=https://discord.gg/OpenShock

PUBLIC_TURNSTILE_DEV_BYPASS_VALUE=INVALID

PUBLIC_DEVELOPMENT_BANNER=false

PUBLIC_DISABLE_ONBOARDING=false

PUBLIC_DISABLE_SHOCKER_MAP=true

PUBLIC_SITE_URL=https://openshock.app
PUBLIC_SITE_SHORT_URL=https://openshock.app
PUBLIC_BACKEND_API_URL=https://api.openshock.app
PUBLIC_GATEWAY_CSP_WILDCARD=https://*.openshock.app

# SigNoz / OpenTelemetry browser log shipping. Disabled by default; only the production
# deployment opts in (see .env.production). The endpoint is also only reachable via CORS/CSP
# from *.openshock.app.
PUBLIC_SIGNOZ_LOGS_ENABLED=false
PUBLIC_SIGNOZ_LOGS_URL=https://signoz.openshock.app/v1/logs
# OTLP traces endpoint (API-call tracing). Defaults to the logs collector origin + /v1/traces.
PUBLIC_SIGNOZ_TRACES_URL=https://signoz.openshock.app/v1/traces
# Propagate W3C trace context (traceparent/tracestate) to the backend API for distributed tracing.
# Requires the backend CORS config to allow those request headers, so off by default.
PUBLIC_SIGNOZ_TRACE_PROPAGATION=false
# Resource attributes attached to every shipped log/trace. `deployment.environment` is broken out
# for convenience; defaults to the build mode (development/production) when left empty.
PUBLIC_SIGNOZ_DEPLOYMENT_ENVIRONMENT=
# Extra OTel resource attributes, comma-separated key=value pairs (same format as the standard
# OTEL_RESOURCE_ATTRIBUTES env var). Example: deployment.region=eu,team=frontend
PUBLIC_SIGNOZ_RESOURCE_ATTRIBUTES=