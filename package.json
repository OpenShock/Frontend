{
	"name": "frontend",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo '' && husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"test:unit": "vitest",
		"regen-api": "node scripts/regenerate-api.js"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "latest",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.7.0",
		"@microsoft/signalr": "^10.0.0",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@tanstack/table-core": "^8.21.3",
		"@types/node": "^25.5.2",
		"@types/semver": "^7.7.1",
		"@types/w3c-web-serial": "^1.0.8",
		"bits-ui": "2.17.2",
		"boxen": "^8.0.1",
		"chalk": "^5.6.2",
		"clsx": "^2.1.1",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-compat": "^7.0.1",
		"eslint-plugin-svelte": "^3.17.0",
		"esptool-js": "0.6.0",
		"formsnap": "^2.0.1",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"prettier": "^3.8.1",
		"prettier-plugin-organize-imports": "^4.3.0",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"rollup-plugin-license": "^3.7.0",
		"semver": "^7.7.4",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"svelte-sonner": "^1.1.0",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"ua-parser-js": "2.0.9",
		"vaul-svelte": "1.0.0-next.7",
		"vite-plugin-devtools-json": "^1.0.0",
		"vite-plugin-mkcert": "^1.17.10",
		"vitest": "^4.1.3"
	},
	"dependencies": {
		"vite": "^8.0.7"
	},
	"engines": {
		"node": ">=24 <25",
		"pnpm": ">=10"
	},
	"volta": {
		"node": "24.14.0"
	},
	"browserslist": [
		"defaults and fully supports es6-module"
	],
	"packageManager": "pnpm@10.33.0",
	"pnpm": {
		"onlyBuiltDependencies": [
			"@tailwindcss/oxide",
			"esbuild",
			"sharp",
			"workerd"
		],
		"patchedDependencies": {
			"@microsoft/signalr@10.0.0": "patches/signalr.patch"
		},
		"overrides": {
			"cookie@<0.7.0": ">=0.7.0",
			"js-yaml@<4.1.1": ">=4.1.1",
			"undici@>=7.0.0 <7.24.0": ">=7.24.0",
			"undici@>=7.17.0 <7.24.0": ">=7.24.0",
			"brace-expansion@<5.0.5": ">=5.0.5"
		}
	}
}
