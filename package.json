{
	"name": "frontend",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "cross-env BUILD_ENV=production vite build",
		"preview": "cross-env BUILD_ENV=production vite preview",
		"prepare": "svelte-kit sync || echo '' && husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"format:check": "prettier --check .",
		"format": "prettier --write .",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"test:unit": "vitest",
		"regen-api": "node scripts/regenerate-api.js",
		"update-shadcn": "node scripts/update-shadcn.js"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "latest",
		"@hey-api/openapi-ts": "^0.99.0",
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.21.0",
		"@microsoft/signalr": "^10.0.0",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/kit": "^2.68.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.1",
		"@tanstack/table-core": "^8.21.3",
		"@types/node": "^26.0.1",
		"@types/semver": "^7.7.1",
		"@types/w3c-web-serial": "^1.0.8",
		"bits-ui": "2.18.1",
		"boxen": "^8.0.1",
		"chalk": "^5.6.2",
		"clsx": "^2.1.1",
		"cross-env": "^10.1.0",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-compat": "^7.0.2",
		"eslint-plugin-svelte": "^3.20.0",
		"esptool-js": "0.6.0",
		"formsnap": "^2.0.1",
		"globals": "^17.7.0",
		"husky": "^9.1.7",
		"prettier": "^3.8.4",
		"prettier-plugin-organize-imports": "^4.3.0",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"rollup-plugin-license": "^3.7.1",
		"semver": "^7.8.5",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"svelte-sonner": "^1.1.1",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.0",
		"ua-parser-js": "2.0.10",
		"vaul-svelte": "1.0.0-next.7",
		"vite-plugin-devtools-json": "^1.0.0",
		"vite-plugin-mkcert": "^2.1.0",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@opentelemetry/api-logs": "^0.219.0",
		"@opentelemetry/exporter-logs-otlp-http": "^0.219.0",
		"@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
		"@opentelemetry/instrumentation": "^0.219.0",
		"@opentelemetry/instrumentation-fetch": "^0.219.0",
		"@opentelemetry/resources": "^2.8.0",
		"@opentelemetry/sdk-logs": "^0.219.0",
		"@opentelemetry/sdk-trace-web": "^2.8.0",
		"driver.js": "^1.6.0",
		"temporal-polyfill": "^1.0.1",
		"vite": "^8.1.0"
	},
	"engines": {
		"node": "=26",
		"pnpm": ">=11"
	},
	"browserslist": [
		"defaults and fully supports es6-module"
	],
	"packageManager": "pnpm@11.8.0"
}
